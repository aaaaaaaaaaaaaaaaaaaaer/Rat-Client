local function CreateAirDashEffect(rootPart)
    if not rootPart then return end
    
    -- Sound replication
    local dashSound = Instance.new("Sound")
    dashSound.SoundId = "rbxassetid://9114223164"
    dashSound.Volume = 1.5
    dashSound.Parent = rootPart
    dashSound:Play()
    Debris:AddItem(dashSound, 1.5)
    
    -- Vibrant Neon Shockwave Configuration
    local fxPart = Instance.new("Part")
    fxPart.Size = Vector3.new(4, 1, 4)
    fxPart.CFrame = rootPart.CFrame * CFrame.Angles(math.rad(90), 0, 0)
    fxPart.Anchored = true
    fxPart.CanCollide = false
    fxPart.Material = Enum.Material.Neon
    fxPart.Color = Color3.fromRGB(0, 255, 255)
    fxPart.Transparency = 0.1
    fxPart.Parent = workspace
    
    local mesh = Instance.new("SpecialMesh")
    mesh.MeshType = Enum.MeshType.FileMesh
    mesh.MeshId = "rbxassetid://3270017"
    mesh.Scale = Vector3.new(1, 0.3, 1)
    mesh.Parent = fxPart
    
    -- Hyper Glowing Neon Particle Trail
    local attachment = Instance.new("Attachment")
    attachment.Position = Vector3.new(0, -0.5, 0)
    attachment.Parent = rootPart
    
    local particles = Instance.new("ParticleEmitter")
    particles.Texture = "rbxassetid://5045435015"
    particles.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 255, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 100, 255))
    })
    particles.LightEmission = 1.0
    particles.LightInfluence = 0.0
    particles.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.0),
        NumberSequenceKeypoint.new(0.7, 0.2),
        NumberSequenceKeypoint.new(1, 1)
    })
    particles.Size = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 4.0),
        NumberSequenceKeypoint.new(1, 0.8)
    })
    particles.Lifetime = NumberRange.new(0.25, 0.45)
    particles.Rate = 220
    particles.Speed = NumberRange.new(8, 20)
    particles.SpreadAngle = Vector2.new(20, 20)
    particles.Parent = attachment
    
    -- Animation interpolations
    TweenService:Create(mesh, TweenInfo.new(0.35, Enum.EasingStyle.QuadOut), {
        Scale = Vector3.new(14, 4, 14)
    }):Play()
    
    TweenService:Create(fxPart, TweenInfo.new(0.35, Enum.EasingStyle.QuadOut), {
        Transparency = 1
    }):Play()
    
    Debris:AddItem(fxPart, 0.4)
    
    task.delay(0.35, function()
        particles.Enabled = false
        task.wait(0.5)
        attachment:Destroy()
    end)
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if SpeedBurstEnabled and input.KeyCode == Enum.KeyCode.Q and not dashDebounce then
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        
        if root and hum then 
            dashDebounce = true
            CreateAirDashEffect(root)
            
            -- Reliable velocity application via LinearVelocity constraints
            local dashAttachment = Instance.new("Attachment")
            dashAttachment.Name = "DashAttachment"
            dashAttachment.Parent = root
            
            local linearVelocity = Instance.new("LinearVelocity")
            linearVelocity.Name = "DashVelocity"
            linearVelocity.Attachment0 = dashAttachment
            linearVelocity.MaxForce = 9e6
            
            -- Calculate look direction or default forward direction
            local moveDirection = hum.MoveDirection
            if moveDirection.Magnitude == 0 then
                moveDirection = root.CFrame.LookVector
            end
            
            linearVelocity.VectorVelocity = moveDirection.Unit * 150
            linearVelocity.Parent = root
            
            -- Active duration of the momentum burst
            task.wait(0.18) 
            linearVelocity:Destroy()
            dashAttachment:Destroy()
            
            -- Dash cooldown reset
            task.wait(0.4)
            dashDebounce = false
        end
    end
end)


-- ==================== TELEPORT & FLING ENGINES ====================
local function GetPlayerByString(str)
    str = string.lower(str)
    for _, p in ipairs(Players:GetPlayers()) do
        if string.sub(string.lower(p.Name), 1, #str) == str or string.sub(string.lower(p.DisplayName), 1, #str) == str then
            return p
        end
    end
    return nil
end

local function TeleportToClosestPlayer()
    local myChar = player.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    
    local closestOpponent = nil
    local shortestDistance = math.huge
    
    for _, opp in ipairs(Players:GetPlayers()) do
        if opp ~= player and opp.Character and opp.Character:FindFirstChild("HumanoidRootPart") then
            local oppHum = opp.Character:FindFirstChildOfClass("Humanoid")
            -- Only track living opponents
            if oppHum and oppHum.Health > 0 then
                local dist = (myRoot.Position - opp.Character.HumanoidRootPart.Position).Magnitude
                if dist < shortestDistance then
                    shortestDistance = dist
                    closestOpponent = opp
                end
            end
        end
    end
    
    if closestOpponent then
        local oppRoot = closestOpponent.Character.HumanoidRootPart
        -- Safely reposition behind the player to maintain field-of-view tracking
        myRoot.CFrame = oppRoot.CFrame * CFrame.new(0, 0, 3)
    else
        splib:MakeNotification({
            Name = "Teleport Error",
            Content = "No valid live players found nearby!",
            Image = "rbxassetid://6026568198",
            Time = 3
        })
    end
end

local function FlingTargetPlayer(target)
    if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then return end
    local myChar = player.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")
    
    if not myRoot or not myHum then return end
    
    local oldCFrame = myRoot.CFrame
    local targetRoot = target.Character.HumanoidRootPart
    
    local oldCameraType = camera.CameraType
    local oldCameraSubject = camera.CameraSubject
    camera.CameraType = Enum.CameraType.Scriptable
    
    local bAV = Instance.new("BodyAngularVelocity")
    bAV.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bAV.AngularVelocity = Vector3.new(0, 999999, 0)
    bAV.Parent = myRoot
    
    local noclipConnection = RunService.Stepped:Connect(function()
        if myChar then
            for _, part in pairs(myChar:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)
    
    myHum:ChangeState(Enum.HumanoidStateType.Physics)
    
    local flingActive = true
    task.spawn(function()
        while flingActive and targetRoot and targetRoot.Parent and myRoot and myRoot.Parent do
            RunService.Heartbeat:Wait()
            
            myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 0) + targetRoot.Velocity * 0.1
            myRoot.Velocity = Vector3.new(99999, 99999, 99999)
            task.wait()
            if not flingActive then break end
            myRoot.Velocity = Vector3.new(-99999, -99999, -99999)
        end
    end)
    
    task.wait(2.5)
    
    flingActive = false
    noclipConnection:Disconnect()
    if bAV then bAV:Destroy() end
    
    myHum:ChangeState(Enum.HumanoidStateType.GettingUp)
    
    if myRoot then
        myRoot.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        myRoot.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        myRoot.Velocity = Vector3.new(0, 0, 0)
        myRoot.RotVelocity = Vector3.new(0, 0, 0)
        
        myRoot.Anchored = true
        task.wait(0.05)
        
        myRoot.CFrame = oldCFrame
        myRoot.Anchored = false
    end
    
    camera.CameraType = oldCameraType
    camera.CameraSubject = oldCameraSubject
end


-- ==================== EMOTE CORE SYSTEM ====================
local function PlayCustomEmote(animationId)
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    if CurrentEmoteTrack then
        CurrentEmoteTrack:Stop()
        CurrentEmoteTrack = nil
    end
    
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. tostring(animationId)
    
    local animator = hum:FindFirstChildOfClass("Animator")
    if not animator then
        animator = Instance.new("Animator")
        animator.Parent = hum
    end
    
    local success, track = pcall(function()
        return animator:LoadAnimation(anim)
    end)
    
    if success and track then
        CurrentEmoteTrack = track
        CurrentEmoteTrack.Looped = true
        CurrentEmoteTrack:Play()
    end
end

local function StopCustomEmote()
    if CurrentEmoteTrack then
        CurrentEmoteTrack:Stop()
        CurrentEmoteTrack:Destroy()
        CurrentEmoteTrack = nil
    end
end


