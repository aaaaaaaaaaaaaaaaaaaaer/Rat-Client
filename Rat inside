local Settings = {
    BoxColor = Color3.fromRGB(255, 0, 0),
    SkeletonColor = Color3.fromRGB(255, 255, 0),
    TextColor = Color3.fromRGB(255, 255, 255),
    TeamColor = true,
    ShowDistance = true,
    ShowName = true,
    Thickness = 2,
    FontSize = 14
}

local ESP_Data = {}

local function RemoveESP(targetPlayer)
    if ESP_Data[targetPlayer] then
        if ESP_Data[targetPlayer].Connections then
            for _, conn in ipairs(ESP_Data[targetPlayer].Connections) do
                conn:Disconnect()
            end
        end
        if ESP_Data[targetPlayer].Box then ESP_Data[targetPlayer].Box:Remove() end
        if ESP_Data[targetPlayer].Name then ESP_Data[targetPlayer].Name:Remove() end
        if ESP_Data[targetPlayer].Distance then ESP_Data[targetPlayer].Distance:Remove() end
        if ESP_Data[targetPlayer].Bones then
            for _, line in pairs(ESP_Data[targetPlayer].Bones) do
                line:Remove()
            end
        end
        ESP_Data[targetPlayer] = nil
    end
end

local function CreateESP(targetPlayer)
    if targetPlayer == player then return end
    if ESP_Data[targetPlayer] then RemoveESP(targetPlayer) end
    
    local Box = Drawing.new("Square")
    Box.Thickness = Settings.Thickness
    Box.Filled = false
    Box.Transparency = 1
    Box.Color = Settings.BoxColor
    Box.Visible = false
    
    local Name = Drawing.new("Text")
    Name.Size = Settings.FontSize
    Name.Center = true
    Name.Outline = true
    Name.Color = Settings.TextColor
    Name.Visible = false
    
    local Distance = Drawing.new("Text")
    Distance.Size = Settings.FontSize - 2
    Distance.Center = true
    Distance.Outline = true
    Distance.Color = Settings.TextColor
    Distance.Visible = false
    
    local Bones = {
        HeadToTorso = Drawing.new("Line"),
        TorsoToLeftArm = Drawing.new("Line"),
        TorsoToRightArm = Drawing.new("Line"),
        TorsoToLeftLeg = Drawing.new("Line"),
        TorsoToRightLeg = Drawing.new("Line")
    }
    
    for _, line in pairs(Bones) do
        line.Thickness = 1.5
        line.Transparency = 1
        line.Color = Settings.SkeletonColor
        line.Visible = false
    end
    
    ESP_Data[targetPlayer] = {
        Box = Box,
        Name = Name,
        Distance = Distance,
        Bones = Bones,
        Connections = {}
    }
    
    local renderConnection = RunService.RenderStepped:Connect(function()
        local Character = targetPlayer.Character
        if not Character then
            Box.Visible = false; Name.Visible = false; Distance.Visible = false
            for _, l in pairs(Bones) do l.Visible = false end
            return
        end
        
        local RootPart = Character:FindFirstChild("HumanoidRootPart")
        local Head = Character:FindFirstChild("Head")
        local Torso = Character:FindFirstChild("Torso") or Character:FindFirstChild("UpperTorso")
        
        local LeftArm = Character:FindFirstChild("Left Arm") or Character:FindFirstChild("LeftUpperArm")
        local RightArm = Character:FindFirstChild("Right Arm") or Character:FindFirstChild("RightUpperArm")
        local LeftLeg = Character:FindFirstChild("Left Leg") or Character:FindFirstChild("LeftUpperLeg")
        local RightLeg = Character:FindFirstChild("Right Leg") or Character:FindFirstChild("RightUpperLeg")
        
        if not RootPart or not Head then
            Box.Visible = false; Name.Visible = false; Distance.Visible = false
            for _, l in pairs(Bones) do l.Visible = false end
            return
        end
        
        local Vector, OnScreen = camera:WorldToViewportPoint(RootPart.Position)
        
        if not OnScreen then
            Box.Visible = false; Name.Visible = false; Distance.Visible = false
            for _, l in pairs(Bones) do l.Visible = false end
            return
        end
        
        if _G.ESP_Enabled then
            local HeadPos = camera:WorldToViewportPoint(Head.Position + Vector3.new(0, 0.5, 0))
            local LegPos = camera:WorldToViewportPoint(RootPart.Position - Vector3.new(0, 3, 0))
            local Height = HeadPos.Y - LegPos.Y
            local Width = Height * 0.6
            
            Box.Size = Vector2.new(Width, Height)
            Box.Position = Vector2.new(Vector.X - Width/2, Vector.Y - Height/2 + 2)
            Box.Color = (Settings.TeamColor and targetPlayer.TeamColor) and targetPlayer.TeamColor.Color or Settings.BoxColor
            Box.Visible = true
            
            if Settings.ShowName then
                Name.Text = targetPlayer.Name
                Name.Position = Vector2.new(Vector.X, HeadPos.Y - 20)
                Name.Visible = true
            else Name.Visible = false end
            
            if Settings.ShowDistance and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local DistanceValue = math.floor((player.Character.HumanoidRootPart.Position - RootPart.Position).Magnitude)
                Distance.Text = DistanceValue .. " studs"
                Distance.Position = Vector2.new(Vector.X, Vector.Y + Height/2 + 5)
                Distance.Visible = true
            else Distance.Visible = false end
        else
            Box.Visible = false; Name.Visible = false; Distance.Visible = false
        end
        
        if _G.Skeleton_Enabled and Torso then
            local pHead = camera:WorldToViewportPoint(Head.Position)
            local pTorso = camera:WorldToViewportPoint(Torso.Position)
            
            local trackingColor = (Settings.TeamColor and targetPlayer.TeamColor) and targetPlayer.TeamColor.Color or Settings.SkeletonColor
            for _, l in pairs(Bones) do l.Color = trackingColor end
            
            Bones.HeadToTorso.From = Vector2.new(pHead.X, pHead.Y)
            Bones.HeadToTorso.To = Vector2.new(pTorso.X, pTorso.Y)
            Bones.HeadToTorso.Visible = true
            
            if LeftArm then
                local pLArm = camera:WorldToViewportPoint(LeftArm.Position)
                Bones.TorsoToLeftArm.From = Vector2.new(pTorso.X, pTorso.Y)
                Bones.TorsoToLeftArm.To = Vector2.new(pLArm.X, pLArm.Y)
                Bones.TorsoToLeftArm.Visible = true
            else Bones.TorsoToLeftArm.Visible = false end
            
            if RightArm then
                local pRArm = camera:WorldToViewportPoint(RightArm.Position)
                Bones.TorsoToRightArm.From = Vector2.new(pTorso.X, pTorso.Y)
                Bones.TorsoToRightArm.To = Vector2.new(pRArm.X, pRArm.Y)
                Bones.TorsoToRightArm.Visible = true
            else Bones.TorsoToRightArm.Visible = false end
            
            if LeftLeg then
                local pLLeg = camera:WorldToViewportPoint(LeftLeg.Position)
                Bones.TorsoToLeftLeg.From = Vector2.new(pTorso.X, pTorso.Y)
                Bones.TorsoToLeftLeg.To = Vector2.new(pLLeg.X, pLLeg.Y)
                Bones.TorsoToLeftLeg.Visible = true
            else Bones.TorsoToLeftLeg.Visible = false end
            
            if RightLeg then
                local pRLeg = camera:WorldToViewportPoint(RightLeg.Position)
                Bones.TorsoToRightLeg.From = Vector2.new(pTorso.X, pTorso.Y)
                Bones.TorsoToRightLeg.To = Vector2.new(pRLeg.X, pRLeg.Y)
                Bones.TorsoToRightLeg.Visible = true
            else Bones.TorsoToRightLeg.Visible = false end
        else
            for _, l in pairs(Bones) do l.Visible = false end
        end
    end)
    
    table.insert(ESP_Data[targetPlayer].Connections, renderConnection)
end

