-- ==================== BLADE BALL CORE ENGINE ====================
local function GetActiveBall()
    for _, v in ipairs(workspace:GetChildren()) do
        if v.Name == "Ball" and v:IsA("BasePart") then
            return v
        end
    end
    local ballsFolder = workspace:FindFirstChild("Balls")
    if ballsFolder then
        for _, b in ipairs(ballsFolder:GetChildren()) do
            if b:IsA("BasePart") then return b end
        end
    end
    return nil
end

local function FireParryRemote()
    local parryRemote = ReplicatedStorage:FindFirstChild("Parry") or 
                        ReplicatedStorage:FindFirstChild("ParryAttempt") or 
                        (ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("Parry"))
                        
    if parryRemote and parryRemote:IsA("RemoteEvent") then
        parryRemote:FireServer()
    else
        game:GetService("VirtualUser"):Button1Down(Vector2.new(0,0), camera.CFrame)
    end
end

RunService.PostSimulation:Connect(function()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local ball = GetActiveBall()
    if not ball then return end
    
    local targetAttribute = ball:GetAttribute("target") or ball:GetAttribute("Target")
    local isTargetingMe = (targetAttribute == player.Name) or (ball:FindFirstChild("Target") and ball.Target.Value == player)
    
    local distance = (root.Position - ball.Position).Magnitude
    local ballVelocity = ball.AssemblyLinearVelocity.Magnitude
    
    local dynamicThreshold = ParryDistanceValue
    if PredictionSystemEnabled and ballVelocity > 60 then
        dynamicThreshold = ParryDistanceValue + (ballVelocity * 0.15)
    elseif ballVelocity > 75 then
        dynamicThreshold = ParryDistanceValue + (ballVelocity * 0.13)
    end
    
    if AutoParryEnabled and not parryDebounce then
        if isTargetingMe and distance <= dynamicThreshold then
            parryDebounce = true
            FireParryRemote()
            task.wait(0.1)
            parryDebounce = false
        end
    end
    
    if BallMagnetEnabled and isTargetingMe then
        camera.CFrame = CFrame.lookAt(camera.CFrame.Position, ball.Position)
    end
end)


-- ==================== FLY CORE ====================
local function startFly()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    local root = char.HumanoidRootPart
    local hum = char:FindFirstChild("Humanoid")
    
    bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bv.Velocity = Vector3.new(0,0,0)
    bv.Parent = root
    
    bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    bg.P = 12500
    bg.Parent = root
    
    if hum then hum.PlatformStand = true end
end

local function stopFly()
    if bv then bv:Destroy() end
    if bg then bg:Destroy() end
    
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.PlatformStand = false
    end
end

RunService.Heartbeat:Connect(function()
    if not FlyEnabled then return end
    
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    local root = char.HumanoidRootPart
    local move = Vector3.new(0,0,0)
    
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then move += camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then move -= camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then move -= camera.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then move += camera.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.new(0,1,0) end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then move -= Vector3.new(0,1,0) end
    
    if move.Magnitude > 0 then
        move = move.Unit
        bv.Velocity = move * FlySpeed
        bg.CFrame = CFrame.lookAt(root.Position, root.Position + move)
    else
        bv.Velocity = Vector3.new(0,0,0)
    end
end)

