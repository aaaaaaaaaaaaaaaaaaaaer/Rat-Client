Tab:AddTextbox({
    IsMobile = false,
    IsPC = false,
    PremiumOnly = false,
    HidePremium = false,
    Name = "Save Slots Exploit (Patched)",
    Desc = "Put a number on how many save slots you want",
    Default = "",
    TextDisappear = true,
    Flag = "textboxsave",
    Callback = function(Value)
        local slotvalue = tonumber(Value)

        if slotvalue then
            for i = 1, slotvalue do
                task.spawn(function()
                    local args = {
                        [1] = 1,
                        [2] = tostring(i) .. "\0",
                        [3] = 0,
                        [4] = ""
                    }

                    workspace:WaitForChild("UpdateSlotOrderRE"):FireServer(unpack(args))
                end)
            end
        end
    end    
})

