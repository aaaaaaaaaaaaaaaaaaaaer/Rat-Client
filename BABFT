local Tab = Window:MakeTab({
    IsMobile = false,
    IsPC = false,
    Name = "Auto Farm",
    Icon = "rbxassetid://4483345998"
})

local autoFarmEnabled = false

Tab:AddToggle({
    IsMobile = false,
    IsPC = false,
    PremiumOnly = false,
    HidePremium = false,
    Name = "Auto Collect Gold",
    Desc = "Automatically Collects Gold",
    Default = false,
    Flag = "ToggleSave",
    Callback = function(Value)
        autoFarmEnabled = Value
        
        if autoFarmEnabled then
            task.spawn(function()
                local remote = game.Workspace:WaitForChild("ClaimRiverResultsGold")
                while autoFarmEnabled do
                    remote:FireServer()
                    task.wait(1)
                end
            end)
        end
    end    
})

Tab:AddToggle({
    IsMobile = false,
    IsPC = false,
    PremiumOnly = false,
    HidePremium = false,
    Name = "Auto Farms Gold",
    Desc = "Automatically Farm Gold (Enable this with the auto collect)",
    Default = false,
    Flag = "ToggleSave",
    Callback = function(Value)
        if Value then
            local Players = game:GetService("Players")
            local Workspace = game:GetService("Workspace")
            local localPlayer = Players.LocalPlayer

            local normalStages = Workspace:WaitForChild("NormalStages")

            for i = 1, 10 do
                local stageName = "CaveStage" .. i
                local stage = normalStages:FindFirstChild(stageName)
                
                if stage then
                    local character = localPlayer.Character
                    if character and character:FindFirstChild("HumanoidRootPart") then
                        character:PivotTo(stage:GetPivot())
                    end
                    task.wait(0.5)
                end
            end
        end
    end
})

